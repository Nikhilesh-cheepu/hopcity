generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Reservation {
  id            String   @id @default(cuid())
  staffType     String
  entryType     String   @default("walkin")
  bookingSource String   @default("direct")
  guestName     String
  mobileNo      String
  partySize     Int
  venue         String
  visitDate     DateTime @db.Date
  createdAt     DateTime @default(now())

  @@index([visitDate])
  @@index([venue])
  @@index([visitDate, venue])
  @@index([entryType])
  @@index([bookingSource])
}
