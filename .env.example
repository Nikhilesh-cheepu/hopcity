# Railway Postgres — copy this file to .env.local and fill in values
# from your Railway project → Postgres service → Variables tab.

# Public URL — required for Vercel, local dev, and Prisma migrations.
# Railway → Postgres → Connect → Public Network (host like *.proxy.rlwy.net)
DATABASE_URL="postgresql://USER:PASSWORD@PUBLIC_HOST:PORT/railway?sslmode=require"

# Optional alias — same public URL if you prefer splitting local vs deploy vars.
DATABASE_PUBLIC_URL="postgresql://USER:PASSWORD@PUBLIC_HOST:PORT/railway?sslmode=require"

# Do NOT use postgres.railway.internal on Vercel — that hostname only works
# inside Railway's private network.

# WhatsApp number that receives staff guest reports (10 digits, no +91)
NEXT_PUBLIC_STAFF_REPORT_WHATSAPP="7013884485"

# Optional — override defaults for staff portal (defaults: staff / hopcitybrew.co/clear)
# STAFF_PASSWORD="staff"
# CLEAR_DATA_PASSWORD="hopcitybrew.co/clear"
